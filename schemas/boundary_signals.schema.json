{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSceneRAG Boundary Signals",
  "type": "object",
  "required": [
    "schema_version",
    "video_id",
    "source_sha256",
    "pipeline_version",
    "time_unit",
    "duration_ms",
    "config",
    "candidate_count",
    "candidates",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "boundary-signals-v1" },
    "video_id": { "type": "string", "minLength": 1 },
    "source_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "pipeline_version": { "type": "string" },
    "time_unit": { "const": "milliseconds" },
    "duration_ms": { "type": "integer", "minimum": 1 },
    "config": { "type": "object" },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["boundary_id", "timestamp_ms", "signals", "score"],
        "properties": {
          "boundary_id": { "type": "string", "pattern": "^boundary_[0-9]{6}$" },
          "timestamp_ms": { "type": "integer", "minimum": 1 },
          "signals": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "duration",
                "sentence_boundary",
                "pause",
                "scene_cut",
                "visual_difference"
              ]
            }
          },
          "score": { "type": "number", "minimum": 0, "maximum": 1 },
          "signal_scores": { "type": "object" },
          "evidence": { "type": "object" }
        },
        "additionalProperties": true
      }
    },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
