{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSceneRAG Atomic Span Validation Report",
  "type": "object",
  "required": [
    "schema_version",
    "video_id",
    "source_sha256",
    "pipeline_version",
    "time_unit",
    "duration_ms",
    "valid",
    "checks",
    "metrics",
    "errors",
    "warnings",
    "validated_at"
  ],
  "properties": {
    "schema_version": { "const": "atom-validation-v1" },
    "video_id": { "type": "string" },
    "source_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "pipeline_version": { "type": "string" },
    "time_unit": { "const": "milliseconds" },
    "duration_ms": { "type": "integer", "minimum": 1 },
    "valid": { "type": "boolean" },
    "checks": { "type": "object" },
    "metrics": { "type": "object" },
    "errors": { "type": "array" },
    "warnings": { "type": "array" },
    "validated_at": { "type": "string" }
  },
  "additionalProperties": true
}
