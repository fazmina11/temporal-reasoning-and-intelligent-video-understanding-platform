{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSceneRAG Canonical Atomic Spans",
  "type": "object",
  "required": [
    "schema_version",
    "video_id",
    "source_sha256",
    "pipeline_version",
    "time_unit",
    "duration_ms",
    "config",
    "atom_count",
    "atoms",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "atomic-spans-v1" },
    "video_id": { "type": "string", "minLength": 1 },
    "source_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "pipeline_version": { "type": "string" },
    "time_unit": { "const": "milliseconds" },
    "duration_ms": { "type": "integer", "minimum": 1 },
    "config": { "type": "object" },
    "atom_count": { "type": "integer", "minimum": 1 },
    "atoms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "video_id",
          "atom_id",
          "start_ms",
          "end_ms",
          "duration_ms",
          "previous_atom_id",
          "next_atom_id",
          "boundary_start_reasons",
          "boundary_end_reasons",
          "boundary_confidence",
          "pipeline_version"
        ],
        "properties": {
          "video_id": { "type": "string" },
          "atom_id": { "type": "string", "pattern": "^atom_[0-9]{6}$" },
          "start_ms": { "type": "integer", "minimum": 0 },
          "end_ms": { "type": "integer", "minimum": 1 },
          "duration_ms": { "type": "integer", "minimum": 1 },
          "previous_atom_id": { "type": ["string", "null"] },
          "next_atom_id": { "type": ["string", "null"] },
          "boundary_confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": true
      }
    },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
