{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VideoSceneRAG Frame Evidence Index",
  "type": "object",
  "required": [
    "schema_version",
    "video_id",
    "source_sha256",
    "pipeline_version",
    "time_unit",
    "duration_ms",
    "source_frame_count",
    "source_fps",
    "mode",
    "all_source_frames_exported",
    "extracted_frame_count",
    "frames",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "frame-index-v1" },
    "video_id": { "type": "string", "minLength": 1 },
    "source_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
    "pipeline_version": { "type": "string" },
    "time_unit": { "const": "milliseconds" },
    "duration_ms": { "type": "integer", "minimum": 1 },
    "source_frame_count": { "type": "integer", "minimum": 1 },
    "source_fps": { "type": "number", "exclusiveMinimum": 0 },
    "mode": { "enum": ["atom_coverage", "all_frames"] },
    "all_source_frames_exported": { "type": "boolean" },
    "extracted_frame_count": { "type": "integer", "minimum": 1 },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "video_id",
          "frame_id",
          "timestamp_ms",
          "source_frame_index",
          "atom_id",
          "sampling_reasons",
          "path",
          "file_size_bytes",
          "sha256",
          "width",
          "height",
          "pipeline_version"
        ],
        "properties": {
          "video_id": { "type": "string" },
          "frame_id": { "type": "string", "pattern": "^frame_[0-9]{9}$" },
          "timestamp_ms": { "type": "integer", "minimum": 0 },
          "source_frame_index": { "type": "integer", "minimum": 0 },
          "atom_id": { "type": "string", "pattern": "^atom_[0-9]{6}$" },
          "sampling_reasons": { "type": "array", "minItems": 1 },
          "path": { "type": "string" },
          "file_size_bytes": { "type": "integer", "minimum": 1 },
          "sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
          "width": { "type": "integer", "minimum": 1 },
          "height": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": true
      }
    },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
