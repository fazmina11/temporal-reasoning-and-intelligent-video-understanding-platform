GEMINI_API_KEY=replace_with_your_gemini_api_key
GEMINI_MODEL=gemini-3-flash-preview
PORT=8001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Optional when ffmpeg/ffprobe are not available through PATH.
# FFMPEG_BIN_DIR=C:\ffmpeg\bin
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe

# Frame evidence defaults. Use all_frames only when every source frame is required.
FRAME_EXTRACTION_MODE=atom_coverage
FRAME_INTERVAL_MS=2000

# Hierarchy Chroma retrieval embeddings.
# Stronger than all-MiniLM-L6-v2 while still practical locally.
HIERARCHY_EMBED_MODEL=BAAI/bge-base-en-v1.5
